name: "multimodal_answerability_judge"
type: "ai-judge"
description: "A pre-generation check to evaluate if the combined text from the retrieved context and parsed artifacts actually contains the information needed to answer the user's query."
model_configuration:
  provider: "anthropic"
  model: "claude-3-5-sonnet"
  temperature: 0.0
required_inputs:
  - "input_text"
  - "input_artifacts_ocr"
  - "retrieved_context"
scoring_scale:
  min: 0
  max: 1
  data_type: "integer"
prompt_template: |
  You are an admissibility judge. Determine if the provided evidence contains the factual information required to answer the user's query.
  
  User Query:
  {{ input_text }}
  
  Evidence Source A (Uploaded Files):
  {{ input_artifacts_ocr }}
  
  Evidence Source B (Database Retrieval):
  {{ retrieved_context }}
  
  If the answer can be logically deduced strictly from the provided Evidence Sources, output a score of 1. 
  If the Evidence Sources are missing the required information, are completely irrelevant, or are too garbled to read, output a score of 0.
